create table inf_agenci (
	id SERIAL PRIMARY KEY,
	nome VARCHAR(40) NOT NULL,
	cnpj VARCHAR(14) NOT NULL UNIQUE,
	numeroagencia VARCHAR(5) NOT NULL UNIQUE,
);

select * from inf_agencia;

create table usuario_inf (
	id SERIAL PRIMARY KEY,
	nome VARCHAR(40) NOT NULL,
	sobrenome VARCHAR(40) NOT NULL,
	cpf VARCHAR(11) NOT NULL UNIQUE,
	email VARCHAR(40) NOT NULL UNIQUE
);

select * from usuario_inf;

create table funcionario (
	id SERIAL PRIMARY KEY,
	namecompleto VARCHAR(40) NOT NULL,
	matricula VARCHAR(40) NOT NULL UNIQUE,
	user_id int UNIQUE,
	FOREIGN KEY (user_id) REFERENCES users(id)
);

select * from funcionario;

CREATE TABLE transacoes (
	id serial PRIMARY KEY,
	data_evento TIMESTAMPTZ NOT NULL,
	valor NUMERIC(30,2),
	conta_id int not null
);

select * from transacoes;

CREATE TABLE conta (
	id serial PRIMARY KEY,
	id_usuario int not null,
	id_agencia int not null,
	numeroconta VARCHAR(12) UNIQUE not null,
	saldo NUMERIC(30,2),
	id_transacoes int unique not null,
	FOREIGN KEY (id_usuario) REFERENCES usuario_inf(id),
	FOREIGN KEY (id_agencia) REFERENCES inf_agencia(id)
);

select * from conta;


create TABLE users (
	id serial PRIMARY key,
	login text not null unique,
	senha text not null,
	regras text not null
);

select * from users;